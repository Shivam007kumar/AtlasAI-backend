# Atlas AI - Environment Configuration Template
# Copy this file to .env and fill in the values.
# NEVER commit the real .env file to version control.

# --- LLM CONFIGURATION ---
# Get your key from https://openrouter.ai/
OPENROUTER_API_KEY=your_api_key_here

# --- SERVER CONFIGURATION ---
PORT=8000
LOG_LEVEL=info

# --- AWS CONFIGURATION (For App Runner) ---
# These are usually set via App Runner Environment Variables or Secrets Manager
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
